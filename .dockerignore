# Git
.git
.gitignore

# Replit specific
.replit
replit.nix
.cache
.upm
.local

# Temp files
*.swp
*.swo
*~
.DS_Store

# Logs (will be created in container)
*.log
app/logs/*.php

# PHP cache
app/cache/*
!app/cache/index.html

# Node modules (if any)
node_modules

